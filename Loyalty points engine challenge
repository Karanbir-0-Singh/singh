# Loyalty points engine challenge
# RULES:
# • Each whole dollar spent earns 3 points
# • Tiers:
#     < 100 pts   →  Bronze
#     100-499 pts → Silver
#     ≥ 500 pts   →  Gold
#
# STEPS:
# 1. Define earn_points(price) → returns points for one purchase
# 2. Define tier_label(points) → returns "Bronze" / "Silver" / "Gold"
# 3. Given the hard-coded list `purchases`,
#    loop through it, call earn_points() for each amount,
#    and add the result to total_points.
# 4. After the loop, call tier_label(total_points)
# 5. Print 'Loyalty Summary':
#       • Total dollars spent
#       • Total points earned
#       • Final tier

# Purchase history (e.g., 3.75, 7.20, etc.)
# 1. Create earn_points function
#
# 2. Create tier_label function
#
# 3. Create total_points variable
#
# 4. Loop through purchases
#
# 5. Convert each purchase to points
#
# 6. Add points to total_points
#
# 7. Find tier from total_points
#
# 8. Print summary
purchases = [12.50,]
def earn_points(price):
    whole_dollar = int(price)
    return whole_dollar * 3

def tier_label(points):
    if points >= 500:
        return "gold"
    if points >= 100 and points <= 499:
        return "silver"
    else:
        return "bronze"

total_dollar = 0.0
total_points = 0
for amount in purchases:
    total_dollar += amount
    total_points += amount * 3

final_tier = tier_label(total_points)

print("------ loyalty summery------")
print(f"total spend: {total_dollar}")
print(f"total points: {total_points}")
print(f"you have {final_tier} card")
