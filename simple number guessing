num = 10
guess = 0
guess_limit = 6
guessed_number = 0

guess = int(input("guess a number from 1-20: "))
guessed_number += 1

while guessed_number < guess_limit:

    if guess != num:
        guessed_number   += 1
        if guess > num:
            guess = int(input("too high, guess again: "))
        else:
            guess = int(input("too low, guess again: "))
    if guess == num:
        print(f"you won, guessed no. is: {guess}")
        break

if guess != num:
    print(f"wrong! guess, it was {num}")
